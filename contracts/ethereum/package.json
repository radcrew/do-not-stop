{
    "name": "ethereum",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "hh": "node scripts/hardhat.js",
        "compile": "pnpm hh compile && node scripts/sync-abi.js",
        "compile:only": "pnpm hh compile",
        "test": "pnpm hh test",
        "node": "pnpm hh node",
        "deploy:local": "pnpm hh ignition deploy ignition/modules/CryptoZombies.ts --network localhost",
        "deploy:sepolia": "pnpm hh ignition deploy ignition/modules/CryptoZombies.ts --network sepolia",
        "deploy:status": "pnpm hh ignition status",
        "deploy:visualize": "pnpm hh ignition visualize ignition/modules/CryptoZombies.ts",
        "deploy:inject": "tsx scripts/deploy.ts"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-ignition": "^3.0.3",
        "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
        "@openzeppelin/contracts": "^5.4.0",
        "@types/node": "^22.18.6",
        "chai": "^4.4.1",
        "hardhat": "^3.0.6",
        "typescript": "~5.8.0",
        "viem": "^2.37.8"
    }
}