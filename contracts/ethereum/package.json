{
    "name": "ethereum",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "hh": "node scripts/hardhat.js",
        "compile:only": "pnpm hh compile --force",
        "compile": "pnpm compile:only && node scripts/sync-abi.js",
        "test": "pnpm hh test",
        "node": "pnpm hh node --hostname 0.0.0.0",
        "deploy:local": "pnpm hh ignition deploy ignition/modules/CryptoPets.ts --network localhost",
        "deploy:sepolia": "pnpm hh ignition deploy ignition/modules/CryptoPetsSepolia.ts --network sepolia",
        "deploy:status": "pnpm hh ignition status",
        "deploy:visualize": "pnpm hh ignition visualize ignition/modules/CryptoPets.ts",
        "deploy:inject": "tsx scripts/deploy.ts"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-ignition": "^3.0.3",
        "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
        "@openzeppelin/contracts": "^5.4.0",
        "@types/node": "^22.18.6",
        "chai": "^4.4.1",
        "hardhat": "^3.2.0",
        "typescript": "~5.8.0",
        "viem": "^2.37.8"
    },
    "dependencies": {
        "@chainlink/contracts": "1.4.0"
    }
}