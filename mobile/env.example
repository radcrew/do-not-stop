# WalletConnect Project ID
# Get your project ID from https://dashboard.reown.com/
REOWN_PROJECT_ID=your_project_id_here

# If you see: WebSocket code 3000 "Unauthorized: origin not allowed"
# → In the same dashboard project, open Allowed domains / Allowlist and either:
#   - Leave it empty while developing (allows any origin), or
#   - Add every origin your app uses, e.g. the exact https URL in AppKit metadata.url,
#     Metro dev server (http://localhost:8081, http://127.0.0.1:8081, http://YOUR_LAN_IP:8081),
#     and native bundle IDs if the dashboard asks for them (e.g. com.cryptopets on Android).
